<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="4"
    android:padding="16dp">
    <!-- Display-->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_columnSpan="4"
        android:textSize="30sp"
        android:gravity="end"
        android:background="#DDDDDD"
        android:padding="10dp" />
    <!-- Row 1-->
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="7" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="8" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="9" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="+" android:onClick="operatorClick"/>
    <!-- Row 2-->
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="4" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="5" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="6" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="-" android:onClick="operatorClick"/>
    <!-- Row 3-->
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="1" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="2" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="3" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="*" android:onClick="operatorClick"/>
    <!-- Row 4-->
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="0" android:onClick="numberClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="C" android:onClick="clearClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="=" android:onClick="equalsClick"/>
    <Button android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_columnWeight="1" android:text="/" android:onClick="operatorClick"/>
</GridLayout>